<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CoolWeatherAPP" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary brand color.-->
        <item name="colorPrimary">@color/oliveWood</item>
        <item name="colorPrimaryVariant">@color/jasmine</item>
        <item name="colorOnPrimary">@color/inkBlack</item>

        <!-- Secondary brand color.-->
        <item name="colorSecondary">@color/camel</item>
        <item name="colorSecondaryVariant">@color/taupe</item>
        <item name="colorOnSecondary">@color/inkBlack</item>

        <!-- Status bar color.-->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Customize your theme here.-->
        <item name="background">@color/charcoalBrown</item>
        <item name="android:textColor">@color/inkBlack</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.CoolWeatherAPP" parent="Base.Theme.CoolWeatherAPP" />

    <style name="Theme.Day" parent="Theme.CoolWeatherAPP">
        <item name = "android:windowBackground" >@drawable/fundo_portrait</item>
    </style>

    <style name="Theme.Day.Land" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/fundo_land</item>
    </style>

    <style name="Theme.Night" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/fundo_night_portrait</item>
    </style>

    <style name="Theme.Night.Land" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/fundo_night_land</item>
    </style>
</resources>